{
  "name": "panster",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun src/dev.ts",
    "css:build": "tailwindcss -i ./src/static/app.tailwind.css -o ./src/static/app.css --minify",
    "css:watch": "tailwindcss -i ./src/static/app.tailwind.css -o ./src/static/app.css --watch",
    "start": "bun run css:build && bun src/index.ts",
    "start:prod": "bun build/index.js",
    "typecheck": "tsc --noEmit",
    "app:build": "bun run css:build && bun src/build.ts",
    "build": "bun run typecheck && bun test && bun run app:build"
  },
  "dependencies": {
    "eta": "^4.6.0",
    "hono": "^4.12.31"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.3",
    "@types/bun": "^1.3.14",
    "typescript": "^7.0.2"
  }
}
