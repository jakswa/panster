<section class="mx-auto max-w-2xl rounded-lg border border-slate-300 bg-white p-8 text-center shadow-sm shadow-slate-900/10">
  <p class="mb-3 text-xs font-extrabold uppercase tracking-[0.14em] text-indigo-600">Error <%= it.status %></p>
  <h1 class="text-[clamp(2rem,6vw,4rem)] font-extrabold leading-none tracking-[-0.05em]"><%= it.title %></h1>
  <p class="mt-4 text-slate-500"><%= it.message %></p>
  <a class="mt-6 inline-flex items-center justify-center rounded-lg bg-indigo-600 px-4 py-2.5 font-bold text-white no-underline hover:bg-indigo-700" href="/">Go home</a>
</section>
